generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assetsCreated Asset[]
}

model Custodian {
  id         Int      @id @default(autoincrement())
  fullName   String
  identifier String   @unique
  unit       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assets     Asset[]
}

model Asset {
  id               Int       @id @default(autoincrement())
  code             String?   @unique
  previousCode     String?
  assetName        String
  brand            String?
  model            String?
  serialNumber     String?
  location         String?
  physicalLocation String?
  entryDate        DateTime?
  activationDate   DateTime?
  accountCode      String?
  initialValue     Decimal?  @db.Decimal(12, 2)
  currentValue     Decimal?  @db.Decimal(12, 2)
  note             String?

  custodianId      Int?
  custodian        Custodian? @relation(fields: [custodianId], references: [id])

  createdByUserId  Int?
  createdByUser    User?       @relation(fields: [createdByUserId], references: [id])

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

